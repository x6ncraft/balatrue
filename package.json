{
  "name": "balatrue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "vue-tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bun run build && playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "data:sync": "bun scripts/sync-jokers.ts",
    "data:validate": "bun scripts/validate-jokers.ts",
    "check": "bun scripts/check.ts"
  },
  "dependencies": {
    "@fontsource/silkscreen": "^5.2.6",
    "lucide-vue-next": "^0.468.0",
    "pinyin-pro": "^3.27.0",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.15",
    "@vue/test-utils": "^2.4.6",
    "bun-types": "^1.3.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^14.0.0",
    "jsdom": "^27.2.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.4",
    "vitest": "^4.0.15",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.5"
  }
}
