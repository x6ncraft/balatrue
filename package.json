{
  "name": "balatrue",
  "version": "0.2.1",
  "private": true,
  "license": "MIT",
  "description": "A daily Balatro Joker guessing game inspired by Wordle, Handle, and Counter-Strikle.",
  "homepage": "https://balatrue.x6n.me/",
  "repository": "github:x6ncraft/balatrue",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && bun run data:validate && vite build && bun scripts/validate-dist.ts",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bun run build && playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "data:sync": "bun scripts/sync-jokers.ts && bun run data:search",
    "data:regenerate": "bun scripts/regenerate-jokers.ts",
    "data:search": "bun scripts/generate-joker-search.ts",
    "data:provenance": "bun scripts/public-provenance.ts",
    "data:generated:check": "bun scripts/check-generated-data.ts",
    "data:validate": "bun run data:generated:check && bun scripts/validate-jokers.ts",
    "check": "bun scripts/check.ts"
  },
  "dependencies": {
    "@fontsource/silkscreen": "^5.2.6",
    "lucide-react": "^0.468.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.15",
    "bun-types": "^1.3.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^14.0.0",
    "jsdom": "^27.2.0",
    "pinyin-pro": "^3.27.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  }
}
